#!/usr/bin/env python3
"""
Arch-Viz: Architecture Visualization CLI for Multi-Agent OpenCode Projects.

Usage:
    ./arch-viz                 # Terminal dashboard (default)
    ./arch-viz --export excalidraw  # Export Excalidraw diagram
    ./arch-viz --export mermaid     # Export Mermaid diagram
    ./arch-viz --export json        # Export raw JSON data
    ./arch-viz --watch              # Watch mode (auto-refresh)

Collects live data from:
  - opencode.json       → Agent/MCP config
  - AGENTS.md           → Agent descriptions & workflows
  - .agents/skills/*/   → Installed skills + SKILL.md
  - skills-lock.json    → Skill source tracking
  - .opencode/rules/    → Rule files
"""

import json
import os
import re
import sys
import textwrap
import time
from dataclasses import dataclass, field, asdict
from datetime import datetime
from pathlib import Path
from typing import Any, Optional

# ─── Config ────────────────────────────────────────────────────────────────
PROJECT_ROOT = Path(__file__).parent.resolve()

# ─── Data Models ───────────────────────────────────────────────────────────


@dataclass
class AgentNode:
    name: str
    mode: str  # primary | subagent
    model: str
    tools: list[str]
    description: str
    color: Optional[str] = None


@dataclass
class SkillNode:
    name: str
    path: str
    description: str
    version: Optional[str] = None
    source: Optional[str] = None


@dataclass
class MCPNode:
    name: str
    type: str  # local | remote
    command: Optional[list[str]] = None
    url: Optional[str] = None
    enabled: bool = True
    status: str = "unknown"


@dataclass
class RuleNode:
    path: str
    name: str
    size: int


@dataclass
class TopologyGraph:
    project_name: str = "agents"
    platform: str = sys.platform
    collected_at: str = ""
    agents: list[AgentNode] = field(default_factory=list)
    skills: list[SkillNode] = field(default_factory=list)
    mcps: list[MCPNode] = field(default_factory=list)
    rules: list[RuleNode] = field(default_factory=list)
    commands: list[dict] = field(default_factory=list)
    total_agents: int = 0
    total_skills: int = 0
    total_mcps: int = 0
    agent_workflows: list[str] = field(default_factory=list)


# ─── Collectors ────────────────────────────────────────────────────────────


def read_json(path: Path) -> dict:
    """Safely read a JSON file."""
    try:
        with open(path, encoding="utf-8") as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def read_file(path: Path) -> str:
    """Safely read a text file."""
    try:
        with open(path, encoding="utf-8") as f:
            return f.read()
    except FileNotFoundError:
        return ""


def collect_agents(config: dict, agents_md: str) -> list[AgentNode]:
    """Collect agents from opencode.json and AGENTS.md."""
    agents = []
    raw_agents = config.get("agent", {})

    # Parse AGENTS.md for agent descriptions
    agent_descriptions: dict[str, str] = {}
    md_table_pattern = re.compile(
        r"\|\s*`(@?\w+)`\s*\|.*?\|.*?\|(.+?)(?=\||$)"
    )
    for match in md_table_pattern.finditer(agents_md):
        name = match.group(1).lstrip("@")
        desc = match.group(2).strip()
        agent_descriptions[name] = desc

    # Parse workflows from AGENTS.md
    for name, raw in raw_agents.items():
        tools = []
        perms = raw.get("permission", {})
        if isinstance(perms, dict):
            for tool, action in perms.items():
                if action in ("allow", True):
                    tools.append(tool)

        desc = agent_descriptions.get(name, raw.get("description", ""))
        if not desc:
            desc = raw.get("prompt", "")[:60] + "..." if raw.get("prompt") else ""

        agents.append(AgentNode(
            name=name,
            mode=raw.get("mode", "primary"),
            model=raw.get("model", ""),
            tools=sorted(tools),
            description=desc,
            color=raw.get("color"),
        ))

    return agents


def collect_skills(skills_path: Path, lock_data: dict) -> list[SkillNode]:
    """Scan .agents/skills/ for installed skills."""
    skills = []
    lock_skills = lock_data.get("skills", {})

    if not skills_path.is_dir():
        return skills

    for skill_dir in sorted(skills_path.iterdir()):
        if not skill_dir.is_dir() or skill_dir.name.startswith("."):
            continue

        meta_path = skill_dir / "SKILL.md"
        description = ""
        version = None
        if meta_path.exists():
            content = meta_path.read_text(encoding="utf-8")
            # Parse YAML front matter and extract description
            if content.startswith("---"):
                parts = content.split("---", 2)
                if len(parts) >= 3:
                    yaml_block = parts[1]
                    # Extract description from YAML
                    desc_match = re.search(r'description:\s*["\']?(.+?)["\']?\s*$', yaml_block, re.MULTILINE | re.DOTALL)
                    if desc_match:
                        description = desc_match.group(1).strip().strip("'\"").strip()
                    # Extract version from YAML
                    ver_match = re.search(r'version:\s*["\']?([\d.]+)["\']?', yaml_block)
                    if ver_match:
                        version = ver_match.group(1)
            # If still no description, skip headings and YAML to find first real sentence
            if not description:
                for line in content.split("\n"):
                    line = line.strip()
                    if line and not line.startswith("---") and not line.startswith("#") and not line.startswith("name:") and not line.startswith("description:") and not line.startswith("version:"):
                        description = line[:100]
                        break

        source = None
        if skill_dir.name in lock_skills:
            source = lock_skills[skill_dir.name].get("source", "")

        skills.append(SkillNode(
            name=skill_dir.name,
            path=str(skill_dir),
            description=description,
            version=version,
            source=source,
        ))

    return skills


def collect_mcps(config: dict) -> list[MCPNode]:
    """Collect MCP servers from opencode.json."""
    mcps = []
    raw_mcps = config.get("mcp", {})

    for name, raw in raw_mcps.items():
        mcp_type = raw.get("type", "local")
        mcps.append(MCPNode(
            name=name,
            type=mcp_type,
            command=raw.get("command"),
            url=raw.get("url"),
            enabled=raw.get("enabled", True),
            status="connected" if raw.get("enabled", True) else "disabled",
        ))

    return mcps


def collect_rules(rules_path: Path) -> list[RuleNode]:
    """Scan .opencode/rules/ for rule files."""
    rules = []
    if not rules_path.is_dir():
        return rules

    for rule_file in sorted(rules_path.iterdir()):
        if rule_file.suffix in (".md", ".txt", ".json"):
            rules.append(RuleNode(
                path=str(rule_file),
                name=rule_file.stem,
                size=rule_file.stat().st_size,
            ))

    return rules


def collect_commands(config: dict) -> list[dict]:
    """Collect custom slash commands."""
    commands = config.get("command", {})
    return [{"name": k, **v} for k, v in commands.items()] if isinstance(commands, dict) else []


def parse_workflows(agents_md: str) -> list[str]:
    """Extract workflow descriptions from AGENTS.md."""
    workflows = []
    in_code_block = False
    for line in agents_md.split("\n"):
        if line.strip().startswith("```"):
            in_code_block = not in_code_block
            continue
        if in_code_block and line.strip():
            workflows.append(line.strip())
    return workflows


def build_graph() -> TopologyGraph:
    """Main orchestrator: run all collectors and build the topology graph."""
    config = read_json(PROJECT_ROOT / "opencode.json")
    agents_md = read_file(PROJECT_ROOT / "AGENTS.md")
    lock_data = read_json(PROJECT_ROOT / "skills-lock.json")

    graph = TopologyGraph(
        project_name=PROJECT_ROOT.name,
        collected_at=datetime.now().isoformat(),
        agents=collect_agents(config, agents_md),
        skills=collect_skills(PROJECT_ROOT / ".agents" / "skills", lock_data),
        mcps=collect_mcps(config),
        rules=collect_rules(PROJECT_ROOT / ".opencode" / "rules"),
        commands=collect_commands(config),
        agent_workflows=parse_workflows(agents_md),
    )
    graph.total_agents = len(graph.agents)
    graph.total_skills = len(graph.skills)
    graph.total_mcps = len(graph.mcps)

    return graph


# ─── Renderers ─────────────────────────────────────────────────────────────


def colorize(text: str, color: str) -> str:
    """Simple terminal color wrapper."""
    colors = {
        "reset": "\033[0m",
        "bold": "\033[1m",
        "dim": "\033[2m",
        "red": "\033[91m",
        "green": "\033[92m",
        "yellow": "\033[93m",
        "blue": "\033[94m",
        "magenta": "\033[95m",
        "cyan": "\033[96m",
        "white": "\033[97m",
    }
    c = colors.get(color, "")
    return f"{c}{text}\033[0m" if c else text


def render_agents_table(agents: list[AgentNode]) -> str:
    """Render agents as a formatted table."""
    if not agents:
        return "  (no agents configured)"

    lines = []
    lines.append(f"  {'Agent':<16} {'Mode':<10} {'Model':<28} {'Tools':<25} {'Description'}")
    lines.append(f"  {'─'*16} {'─'*10} {'─'*28} {'─'*25} {'─'*30}")

    for a in agents:
        name = f"@{a.name}"
        tools = ", ".join(a.tools[:4])
        if len(a.tools) > 4:
            tools += "..."
        desc = a.description[:28] + "..." if len(a.description) > 28 else a.description
        lines.append(f"  {name:<16} {a.mode:<10} {a.model:<28} {tools:<25} {desc}")

    return "\n".join(lines)


def render_skills_tree(skills: list[SkillNode]) -> str:
    """Render skills as a table with descriptions."""
    if not skills:
        return "  (no skills installed)"

    lines = []
    lines.append(f"  {'Name':<30} {'Version':<10} {'Source':<30} {'Description'}")
    lines.append(f"  {'─'*30} {'─'*10} {'─'*30} {'─'*40}")
    for s in skills:
        name = colorize(s.name, "cyan")
        ver = s.version or "-"
        src = (s.source or "-")[:28]
        desc = s.description[:50] + "..." if len(s.description) > 50 else s.description
        lines.append(f"  {name:<30} {ver:<10} {src:<30} {desc}")

    return "\n".join(lines)


def render_mcp_table(mcps: list[MCPNode]) -> str:
    """Render MCP servers as a status table."""
    if not mcps:
        return "  (no MCP servers configured)"

    lines = []
    lines.append(f"  {'Name':<20} {'Type':<8} {'Status':<12} {'Endpoint'}")
    lines.append(f"  {'─'*20} {'─'*8} {'─'*12} {'─'*40}")

    for m in mcps:
        status_color = "green" if m.status == "connected" else "yellow" if m.status == "unknown" else "red"
        status = colorize(m.status, status_color)
        endpoint = " ".join(m.command) if m.command else (m.url or "-")
        endpoint = endpoint[:40] + "..." if len(endpoint) > 40 else endpoint
        lines.append(f"  {m.name:<20} {m.type:<8} {status:<12} {endpoint}")

    return "\n".join(lines)


def render_rules_list(rules: list[RuleNode]) -> str:
    """Render rule files."""
    if not rules:
        return "  (no rule files)"
    return "\n".join(f"  ├── {r.name}.md  ({r.size} bytes)" for r in rules)


def render_summary(graph: TopologyGraph) -> str:
    """Render summary panel with stats."""
    active_agents = sum(1 for a in graph.agents if a.mode == "primary")
    sub_agents = sum(1 for a in graph.agents if a.mode == "subagent")
    enabled_mcps = sum(1 for m in graph.mcps if m.enabled)

    lines = [
        f"  {colorize('Project:', 'bold')}       {graph.project_name}",
        f"  {colorize('Platform:', 'bold')}      {graph.platform}",
        f"  {colorize('Collected:', 'bold')}     {graph.collected_at[:19]}",
        "",
        f"  {colorize('📊 Statistics', 'bold')}",
        f"  ├── Agents:    {graph.total_agents} ({active_agents} primary + {sub_agents} sub)",
        f"  ├── Skills:    {graph.total_skills}",
        f"  ├── MCPs:      {graph.total_mcps} ({enabled_mcps} enabled)",
        f"  ├── Commands:  {len(graph.commands)}",
        f"  └── Rules:     {len(graph.rules)}",
    ]
    return "\n".join(lines)


def render_workflows(workflows: list[str]) -> str:
    """Render workflow pipelines."""
    if not workflows:
        return "  (no workflows defined)"
    return "\n".join(f"  {colorize('⤷', 'dim')} {w}" for w in workflows)


def render_dashboard(graph: TopologyGraph) -> str:
    """Render the full terminal dashboard."""
    sep = colorize("─" * 70, "dim")

    sections = [
        (f"\n{colorize(' 🧠  ARCH-VIZ  ·  Architecture Visualization', 'bold',)}{colorize(f'  ({graph.collected_at[:19]})', 'dim')}"),
        sep,
        ("", render_summary(graph)),
        "",
        sep,
        (f"\n{colorize(' 🤖  Agents', 'bold')}  {colorize(f'({graph.total_agents} total)', 'dim')}", render_agents_table(graph.agents)),
        "",
        sep,
        (f"\n{colorize(' 🛠️  Skills', 'bold')}  {colorize(f'({graph.total_skills} installed)', 'dim')}", render_skills_tree(graph.skills)),
        "",
        sep,
        (f"\n{colorize(' 🔗  MCP Servers', 'bold')}  {colorize(f'({graph.total_mcps} configured)', 'dim')}", render_mcp_table(graph.mcps)),
        "",
        sep,
        (f"\n{colorize(' 📜  Workflows', 'bold')}", render_workflows(graph.agent_workflows)),
        "",
        sep,
        (f"\n{colorize(' 📋  Custom Commands', 'bold')}", render_commands(graph.commands) if graph.commands else "  (none)"),
        "",
        sep,
        (f"\n{colorize(' 📁  Rule Files', 'bold')}", render_rules_list(graph.rules)),
        "",
        sep,
        colorize(f"\n ✅  Collected from {len(graph.agents) + len(graph.skills) + len(graph.mcps)} data sources  |  Use --export to generate diagrams\n", "dim"),
    ]

    output = []
    for section in sections:
        if isinstance(section, tuple):
            title, content = section
            output.append(title)
            output.append(content)
        else:
            output.append(section)

    return "\n".join(output)


def render_commands(commands: list[dict]) -> str:
    """Render custom commands."""
    if not commands:
        return "  (no commands)"
    lines = []
    for cmd in commands:
        agent = cmd.get("agent", "")
        desc = cmd.get("description", cmd.get("template", "")[:40])
        lines.append(f"  ├── /{cmd['name']:<12} → @{agent:<12} {desc}")
    return "\n".join(lines)


# ─── Exporters ─────────────────────────────────────────────────────────────


def export_json(graph: TopologyGraph, path: Path) -> str:
    """Export graph data as JSON."""
    data = {
        "project": graph.project_name,
        "collected_at": graph.collected_at,
        "agents": [asdict(a) for a in graph.agents],
        "skills": [asdict(s) for s in graph.skills],
        "mcps": [asdict(m) for m in graph.mcps],
        "rules": [asdict(r) for r in graph.rules],
        "commands": graph.commands,
        "workflows": graph.agent_workflows,
        "statistics": {
            "agents": graph.total_agents,
            "skills": graph.total_skills,
            "mcps": graph.total_mcps,
        },
    }
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    return str(path)


def export_mermaid(graph: TopologyGraph, path: Path) -> str:
    """Export as Mermaid flowchart."""
    lines = ["graph TD", f'  title["{graph.project_name} Architecture"]', '  title:::hidden', ""]

    # Agents
    lines.append("  %% Agents")
    for a in graph.agents:
        tools = ", ".join(a.tools[:3]) if a.tools else "read-only"
        lines.append(f'  agent_{a.name}["@{a.name}\\n{a.model.split("/")[-1]}\\n({tools})"]')

    lines.append("")
    lines.append("  %% Agent Relationships")
    # Link plan → build → reviewer
    if any(a.name == "plan" for a in graph.agents):
        lines.append("  agent_plan -->|designs| agent_build")
    if any(a.name == "build" for a in graph.agents) and any(a.name == "reviewer" for a in graph.agents):
        lines.append("  agent_build -->|reviewed by| agent_reviewer")
    if any(a.name == "build" for a in graph.agents) and any(a.name == "test" for a in graph.agents):
        lines.append("  agent_build -->|tested by| agent_test")

    lines.append("")
    lines.append("  %% Skills")
    lines.append("  subgraph Skills[Installed Skills]")
    for s in graph.skills:
        lines.append(f'    skill_{s.name}["{s.name}"]')
    lines.append("  end")

    lines.append("")
    lines.append("  %% MCP")
    for m in graph.mcps:
        status_icon = "✅" if m.enabled else "❌"
        lines.append(f'  mcp_{m.name}["{status_icon} {m.name} ({m.type})"]')

    lines.append("")
    lines.append("  %% Frontend")
    lines.append("  subgraph Frontend[Dashboard (.opencode/dashboard.html)]")
    lines.append('    login["🔐 Login (kobe/kobe)"]')
    lines.append('    dashboard["📊 Main Dashboard"]')
    lines.append('    live["📡 Live Output"]')
    lines.append('    tasks["⚡ Background Tasks"]')
    lines.append('    ralph["🔄 Ralph Loop"]')
    lines.append('    pipeline["🔗 Pipelines"]')
    lines.append("  end")
    lines.append("  login -->|authenticate| dashboard")
    lines.append("  dashboard --> live")
    lines.append("  dashboard --> tasks")
    lines.append("  dashboard --> ralph")
    lines.append("  dashboard --> pipeline")

    lines.append("")
    lines.append("  %% APIs")
    lines.append("  %% Styling")
    lines.append("  classDef primary fill:#d0ebff,stroke:#1e1e1e")
    lines.append("  classDef subagent fill:#f1f3f5,stroke:#868e96,stroke-dasharray: 5 5")
    lines.append("  classDef hidden display:none")

    # Apply classes
    for a in graph.agents:
        cls = "primary" if a.mode == "primary" else "subagent"
        lines.append(f"  class agent_{a.name} {cls}")

    with open(path, "w", encoding="utf-8") as f:
        f.write("\n".join(lines))
    return str(path)


def export_excalidraw(graph: TopologyGraph, path: Path) -> str:
    """Export as Excalidraw diagram with login module."""
    generator = PROJECT_ROOT / "generate-arch-viz-diagram.py"
    if generator.exists():
        import subprocess
        import json
        result = subprocess.run([sys.executable, str(generator)], capture_output=True, text=True, cwd=PROJECT_ROOT)
        output_path = PROJECT_ROOT / "arch-viz-architecture.excalidraw"
        if result.returncode == 0 and output_path.exists():
            # Append login module to the generated diagram
            try:
                diagram = json.loads(output_path.read_text(encoding="utf-8"))
                els = diagram.get("elements", [])
                # Login module (between subtitle and CLI layer, no overlap)
                import time
                eid = lambda: f"el-{int(time.time()*100000) % 10**6}"
                # Box
                els.insert(2, {
                    "type": "rectangle", "version": 1, "id": eid(),
                    "x": 440, "y": 63, "width": 400, "height": 22, "angle": 0,
                    "strokeColor": "#2f9e44", "backgroundColor": "#b2f2bb",
                    "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
                    "roughness": 0, "opacity": 100, "groupIds": [],
                    "roundness": {"type": 3}, "boundElements": None, "updated": int(time.time()*1000),
                    "link": None, "locked": False, "frameId": None, "isDeleted": False,
                })
                els.insert(3, {
                    "type": "text", "version": 1, "id": eid(),
                    "x": 450, "y": 66, "width": 380, "height": 16, "angle": 0,
                    "strokeColor": "#2f9e44", "backgroundColor": "transparent",
                    "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
                    "roughness": 0, "opacity": 100, "groupIds": [],
                    "roundness": None, "boundElements": None, "updated": int(time.time()*1000),
                    "link": None, "locked": False, "text": "🔐 Login: kobe/kobe  |  Authorized users can access all agents, skills, and MCP services",
                    "fontSize": 10, "fontFamily": 2, "textAlign": "center",
                    "verticalAlign": "middle", "containerId": None, "autoResize": False,
                    "lineHeight": 1, "frameId": None, "isDeleted": False, "originalText": "🔐 Login: kobe/kobe  |  Authorized users can access all agents, skills, and MCP services",
                })
                diagram["elements"] = els
                output_path.write_text(json.dumps(diagram, indent=2, ensure_ascii=False), encoding="utf-8")
                return str(output_path)
            except Exception:
                pass
        print(f"Warning: generator failed: {result.stderr}", file=sys.stderr)
        return ""
    print("Note: generate-arch-viz-diagram.py not found, generating minimal diagram", file=sys.stderr)
    return ""

    # Fallback: generate minimal diagram
    print("Note: generate-arch-viz-diagram.py not found, generating minimal diagram", file=sys.stderr)
    return ""


# ─── Background Task Manager ───────────────────────────────────────────────

ARCH_VIZ_DIR = PROJECT_ROOT / ".arch-viz"
TASKS_FILE = ARCH_VIZ_DIR / "tasks.json"
LOGS_DIR = ARCH_VIZ_DIR / "logs"
MAX_CONCURRENCY = 3


@dataclass
class BackgroundTask:
    id: str
    name: str
    command: str
    status: str = "pending"
    pid: Optional[int] = None
    created_at: str = ""
    started_at: Optional[str] = None
    completed_at: Optional[str] = None
    exit_code: Optional[int] = None
    log_file: Optional[str] = None
    ralph_loop: int = 0
    ralph_count: int = 0
    ralph_promise: str = ""


def _ensure_dir():
    ARCH_VIZ_DIR.mkdir(parents=True, exist_ok=True)
    LOGS_DIR.mkdir(parents=True, exist_ok=True)


def _load_tasks() -> list[BackgroundTask]:
    _ensure_dir()
    if not TASKS_FILE.exists():
        return []
    try:
        data = json.loads(TASKS_FILE.read_text(encoding="utf-8"))
        return [BackgroundTask(**t) for t in data]
    except (json.JSONDecodeError, KeyError):
        return []


def _save_tasks(tasks: list[BackgroundTask]):
    _ensure_dir()
    TASKS_FILE.write_text(json.dumps([asdict(t) for t in tasks], indent=2, ensure_ascii=False), encoding="utf-8")


def _next_id(tasks: list[BackgroundTask]) -> str:
    return f"task-{len(tasks) + 1:03d}"


def _running_count(tasks: list[BackgroundTask]) -> int:
    return sum(1 for t in tasks if t.status == "running")


def _start_task(task: BackgroundTask):
    import subprocess
    task.status = "running"
    task.started_at = datetime.now().isoformat()
    status_file = Path(task.log_file).with_suffix(".exit")
    wrapped = f"({task.command}); echo $? > {status_file}"
    fh = Path(task.log_file).open("w", encoding="utf-8")
    proc = subprocess.Popen(wrapped, shell=True, stdout=fh, stderr=subprocess.STDOUT, cwd=PROJECT_ROOT, preexec_fn=os.setsid if hasattr(os, 'setsid') else None)
    task.pid = proc.pid
    fh.close()


def _try_start_pending():
    tasks = _load_tasks()
    if _running_count(tasks) >= MAX_CONCURRENCY:
        return
    for t in tasks:
        if t.status == "pending":
            _start_task(t)
            _save_tasks(tasks)
            return


def bg_spawn(name: str, command: str, ralph_loop: int = 0, ralph_promise: str = "") -> BackgroundTask:
    tasks = _load_tasks()
    tid = _next_id(tasks)
    t = BackgroundTask(id=tid, name=name, command=command, status="pending", ralph_loop=ralph_loop, ralph_promise=ralph_promise, created_at=datetime.now().isoformat(), log_file=str(LOGS_DIR / f"{tid}.log"))
    if _running_count(tasks) < MAX_CONCURRENCY:
        _start_task(t)
    tasks.append(t)
    _save_tasks(tasks)
    return t


def _pid_alive(pid: int):
    try:
        exit_file = None
        for t in _load_tasks():
            if t.pid == pid and t.log_file:
                exit_file = Path(t.log_file).with_suffix(".exit")
                break
        if exit_file and exit_file.exists():
            ec = int(exit_file.read_text().strip().split()[0])
            return False, ec
        os.kill(pid, 0)
        return True, None
    except (ProcessLookupError, ValueError):
        return False, -1
    except PermissionError:
        return True, None
    except OSError:
        return False, -1


def bg_list() -> list[BackgroundTask]:
    tasks = _load_tasks()
    changed = False
    for t in tasks:
        if t.status == "running" and t.pid:
            alive, ec = _pid_alive(t.pid)
            if not alive:
                t.status = "completed" if ec == 0 else "failed"
                t.exit_code = ec
                t.completed_at = datetime.now().isoformat()
                changed = True
    if changed:
        _save_tasks(tasks)
        _try_start_pending()
    ralph_process_all()
    pipeline_check_progress()
    return tasks


def bg_cancel(task_id: str) -> bool:
    tasks = _load_tasks()
    for t in tasks:
        if t.id == task_id:
            if t.status == "running" and t.pid:
                try:
                    os.kill(t.pid, 15)
                    import time; time.sleep(0.3)
                    try:
                        os.kill(t.pid, 0)
                        os.kill(t.pid, 9)
                    except OSError:
                        pass
                except OSError:
                    pass
            t.status = "cancelled"
            t.completed_at = datetime.now().isoformat()
            _save_tasks(tasks)
            _try_start_pending()
            return True
    return False


def bg_logs(task_id: str, tail: int = 50) -> Optional[str]:
    for t in _load_tasks():
        if t.id == task_id and t.log_file and Path(t.log_file).exists():
            lines = Path(t.log_file).read_text(encoding="utf-8").splitlines()
            return "\n".join(lines[-tail:])
    return None


def ralph_retry(task_id: str) -> bool:
    """Ralph Loop: retry a failed task. Returns True if retried."""
    tasks = _load_tasks()
    for t in tasks:
        if t.id != task_id: continue
        if t.ralph_loop <= 0 or t.ralph_count >= t.ralph_loop: return False
        if t.ralph_promise and t.log_file and Path(t.log_file).exists():
            if t.ralph_promise in Path(t.log_file).read_text(errors="replace"):
                t.status = "completed"
                t.exit_code = 0
                _save_tasks(tasks)
                return False
        t.ralph_count += 1
        t.status = "pending"
        t.pid = None
        t.exit_code = None
        t.started_at = None
        t.completed_at = None
        if t.log_file and Path(t.log_file).exists(): Path(t.log_file).write_text("")
        _save_tasks(tasks)
        _try_start_pending()
        return True
    return False


def ralph_process_all():
    """Run Ralph Loop on all failed tasks."""
    for t in _load_tasks():
        if t.status == "failed" and t.ralph_loop > 0:
            ralph_retry(t.id)


def render_bg_tasks_html(tasks: list[BackgroundTask]) -> str:
    if not tasks:
        return "<tr><td colspan='5' style='color:#8b949e;text-align:center;padding:16px;'>no background tasks</td></tr>"
    active = [t for t in tasks if t.status in ("running", "pending")]
    recent = [t for t in tasks if t.status not in ("running", "pending")][-5:]
    icons = {"running": "🟢", "pending": "🟡", "completed": "✅", "failed": "❌", "cancelled": "⏹"}
    rows = ""
    for t in (active + recent)[:10]:
        dur = ""
        if t.started_at:
            s = datetime.fromisoformat(t.started_at)
            e = datetime.fromisoformat(t.completed_at) if t.completed_at else datetime.now()
            dur = f"{int((e-s).total_seconds())}s"
        cmd_short = t.command[:35] + "..." if len(t.command) > 38 else t.command
        rows += f"<tr><td><code>{t.id}</code></td><td>{t.name}</td><td>{icons.get(t.status,'⬜')} {t.status}</td><td>{dur}</td><td><code>{cmd_short}</code></td></tr>"
    return rows


# ─── Pipeline Orchestrator ───────────────────────────────────────
# Chains multiple agents: plan → build → test → review
# Each step's output is automatically passed to the next.

PIPELINE_FILE = ARCH_VIZ_DIR / "pipelines.json"

@dataclass
class PipelineStep:
    agent: str
    task: str
    status: str = "pending"  # pending | running | completed | failed
    task_id: Optional[str] = None
    output: str = ""


@dataclass
class Pipeline:
    id: str
    name: str
    description: str
    steps: list[PipelineStep]
    status: str = "pending"  # pending | running | completed | failed
    current_step: int = 0
    created_at: str = ""


def _load_pipelines() -> list[Pipeline]:
    if not PIPELINE_FILE.exists():
        return []
    try:
        data = json.loads(PIPELINE_FILE.read_text(encoding="utf-8"))
        result = []
        for p in data:
            p["steps"] = [PipelineStep(**s) for s in p.get("steps", [])]
            result.append(Pipeline(**p))
        return result
    except (json.JSONDecodeError, KeyError):
        return []


def _save_pipelines(pipelines: list[Pipeline]):
    PIPELINE_FILE.parent.mkdir(parents=True, exist_ok=True)
    PIPELINE_FILE.write_text(json.dumps([{**asdict(p)} for p in pipelines], indent=2, ensure_ascii=False), encoding="utf-8")


def pipeline_create(name: str, description: str, steps: list[PipelineStep]) -> Pipeline:
    pipelines = _load_pipelines()
    pid = f"pipe-{len(pipelines) + 1:03d}"
    p = Pipeline(id=pid, name=name, description=description, steps=steps, created_at=datetime.now().isoformat())
    pipelines.append(p)
    _save_pipelines(pipelines)
    return p


def pipeline_advance(pid: str) -> bool:
    """Advance a pipeline: run the next pending step."""
    pipelines = _load_pipelines()
    for p in pipelines:
        if p.id != pid:
            continue
        if p.status != "running":
            return False
        if p.current_step >= len(p.steps):
            p.status = "completed"
            _save_pipelines(pipelines)
            return False

        step = p.steps[p.current_step]
        # Build the command: if there's output from previous step, append it
        cmd = step.task
        if p.current_step > 0:
            prev = p.steps[p.current_step - 1]
            if prev.output:
                cmd += f" && echo '--- Previous output ---' && echo \"{prev.output[:200]}\""
                cmd += f" && echo '--- End of previous output ---'"

        task = bg_spawn(name=f"{pid}-step-{p.current_step + 1}", command=cmd)
        step.task_id = task.id
        step.status = "running"
        p.status = "running"
        _save_pipelines(pipelines)
        return True
    return False


def pipeline_start(pid: str) -> bool:
    """Start a pipeline from the beginning."""
    pipelines = _load_pipelines()
    for p in pipelines:
        if p.id == pid:
            p.status = "running"
            p.current_step = 0
            _save_pipelines(pipelines)
            pipeline_advance(pid)
            return True
    return False


def pipeline_check_progress():
    """Check if current step is done, advance if so."""
    pipelines = _load_pipelines()
    changed = False
    for p in pipelines:
        if p.status != "running":
            continue
        step = p.steps[p.current_step]
        if step.task_id:
            tasks = _load_tasks()
            for t in tasks:
                if t.id == step.task_id:
                    if t.status == "completed":
                        step.status = "completed"
                        step.output = bg_logs(step.task_id, tail=50) or ""
                        p.current_step += 1
                        changed = True
                        # Check if pipeline is done
                        if p.current_step >= len(p.steps):
                            p.status = "completed"
                        else:
                            pipeline_advance(p.id)
                    elif t.status == "failed":
                        step.status = "failed"
                        step.output = bg_logs(step.task_id, tail=20) or ""
                        p.status = "failed"
                        changed = True
                    break
    if changed:
        _save_pipelines(pipelines)


def render_pipelines_terminal(pipelines: list[Pipeline]) -> str:
    if not pipelines:
        return "  (no pipelines)"
    lines = []
    for p in pipelines[-5:]:
        icon = {"running": "🟢", "completed": "✅", "failed": "❌", "pending": "⏸"}.get(p.status, "⬜")
        lines.append(f"\n  {icon} {p.id} · {p.name}")
        lines.append(f"     {p.description[:60]}")
        for i, s in enumerate(p.steps):
            sicon = {"running": "🟢", "completed": "✅", "failed": "❌", "pending": "⏳"}.get(s.status, "⬜")
            marker = "→" if i == p.current_step else " "
            lines.append(f"     {marker} {sicon} [{s.agent}] {s.task[:50]}")
    return "\n".join(lines)


def render_pipelines_html(pipelines: list[Pipeline]) -> str:
    if not pipelines:
        return ""
    rows = ""
    for p in pipelines[-3:]:
        status_icon = {"running": "🟢", "completed": "✅", "failed": "❌", "pending": "⏸"}.get(p.status, "⬜")
        steps_html = ""
        for i, s in enumerate(p.steps):
            sicon = {"running": "🟢", "completed": "✅", "failed": "❌", "pending": "🟡"}.get(s.status, "⬜")
            steps_html += f"<div style='padding:4px 0;font-size:12px;'>{'&nbsp;&nbsp;' if i == p.current_step else ''}{sicon} [{s.agent}] {s.task[:40]}</div>"
        rows += f"<div style='padding:8px 16px;border-bottom:1px solid #21262d;'><div style='font-weight:bold;font-size:13px;'>{status_icon} {p.name}</div>{steps_html}</div>"
    return rows


# ─── Review System ────────────────────────────────────────────────

REVIEW_FILE = ARCH_VIZ_DIR / "reviews.json"

@dataclass
class Review:
    id: str
    title: str
    description: str
    author: str = "build"
    reviewer: str = "reviewer"
    status: str = "pending"  # pending | approved | changes_requested
    comments: list = field(default_factory=list)
    created_at: str = ""
    updated_at: str = ""
    pipeline_id: str = ""


def _load_reviews() -> list[Review]:
    if not REVIEW_FILE.exists():
        return []
    try:
        data = json.loads(REVIEW_FILE.read_text(encoding="utf-8"))
        result = []
        for r in data:
            r["comments"] = r.get("comments", [])
            result.append(Review(**r))
        return result
    except (json.JSONDecodeError, KeyError):
        return []


def _save_reviews(reviews: list[Review]):
    REVIEW_FILE.parent.mkdir(parents=True, exist_ok=True)
    REVIEW_FILE.write_text(json.dumps([{**asdict(r)} for r in reviews], indent=2, ensure_ascii=False), encoding="utf-8")


def review_create(title: str, description: str, pipeline_id: str = "") -> Review:
    reviews = _load_reviews()
    rid = f"review-{len(reviews) + 1:03d}"
    r = Review(id=rid, title=title, description=description, pipeline_id=pipeline_id, created_at=datetime.now().isoformat(), updated_at=datetime.now().isoformat())
    reviews.append(r)
    _save_reviews(reviews)
    return r


def review_add_comment(review_id: str, author: str, text: str) -> bool:
    reviews = _load_reviews()
    for r in reviews:
        if r.id == review_id:
            r.comments.append({"author": author, "text": text, "at": datetime.now().isoformat()})
            r.updated_at = datetime.now().isoformat()
            _save_reviews(reviews)
            return True
    return False


def review_approve(review_id: str) -> bool:
    reviews = _load_reviews()
    for r in reviews:
        if r.id == review_id:
            r.status = "approved"
            r.updated_at = datetime.now().isoformat()
            _save_reviews(reviews)
            # If linked to a pipeline, advance it
            if r.pipeline_id:
                pipelines = _load_pipelines()
                for p in pipelines:
                    if p.id == r.pipeline_id and p.status == "waiting_review":
                        p.status = "running"
                        _save_pipelines(pipelines)
                        pipeline_advance(r.pipeline_id)
                        break
            return True
    return False


def review_request_changes(review_id: str, comment: str) -> bool:
    reviews = _load_reviews()
    for r in reviews:
        if r.id == review_id:
            r.status = "changes_requested"
            r.comments.append({"author": "reviewer", "text": comment, "at": datetime.now().isoformat()})
            r.updated_at = datetime.now().isoformat()
            _save_reviews(reviews)
            return True
    return False


def review_submit_for_pipeline(pid: str) -> Optional[Review]:
    """Create a review for a pipeline step (reviewer agent)."""
    pipelines = _load_pipelines()
    for p in pipelines:
        if p.id == pid:
            step = p.steps[p.current_step] if p.current_step < len(p.steps) else None
            if step and step.agent == "reviewer":
                r = review_create(f"Review: {p.name}", step.task, pipeline_id=pid)
                p.status = "waiting_review"
                _save_pipelines(pipelines)
                return r
    return None


def render_reviews_terminal(reviews: list[Review]) -> str:
    if not reviews:
        return "  (no reviews)"
    lines = []
    for r in reviews[-10:]:
        icon = {"pending": "⏳", "approved": "✅", "changes_requested": "🔄"}.get(r.status, "⬜")
        comment_count = len(r.comments)
        lines.append(f"  {icon} {r.id:<12} {r.title:<30} {r.status:<18} {comment_count} comments")
        if r.comments:
            last = r.comments[-1]
            lines.append(f"      └─ {last['author']}: {last['text'][:50]}")
    return "\n".join(lines)


def render_reviews_html(reviews: list[Review]) -> str:
    if not reviews:
        return ""
    rows = ""
    for r in reviews[-5:]:
        icon = {"pending": "⏳", "approved": "✅", "changes_requested": "🔄"}.get(r.status, "⬜")
        last_comment = r.comments[-1]["text"][:60] if r.comments else ""
        rows += f"<div style='padding:8px 16px;border-bottom:1px solid #21262d;font-size:12px;'>"
        rows += f"<div><strong>{icon} {r.title}</strong> <span style='color:#8b949e;'>[{r.status}]</span></div>"
        if last_comment:
            rows += f"<div style='color:#8b949e;margin-top:2px;'>{last_comment}</div>"
        rows += f"</div>"
    return rows


