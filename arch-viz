def print_help():
    print(textwrap.dedent("""\
    Usage: ./arch-viz [OPTIONS]

    Architecture Visualization CLI for Multi-Agent OpenCode Projects.

    Options:
        --export FORMAT    Export diagram (excalidraw | mermaid | json)
        --output FILE      Output file path (default: auto-generated)
        --watch            Watch mode (refresh every 5s)
        --serve [PORT]     Start web dashboard (default port: 8080)
        --json             Alias for --export json
        --mermaid          Alias for --export mermaid
        --help             Show this message
    """))


def main():
    args = sys.argv[1:]

    if "--help" in args or "-h" in args:
        print_help()
        return

    export_format = None
    output_path = None
    watch_mode = "--watch" in args

    # Parse --export
    if "--export" in args:
        idx = args.index("--export")
        if idx + 1 < len(args):
            export_format = args[idx + 1]
    if "--json" in args:
        export_format = "json"
    if "--mermaid" in args:
        export_format = "mermaid"

    # Parse --output
    if "--output" in args:
        idx = args.index("--output")
        if idx + 1 < len(args):
            output_path = args[idx + 1]

    # Parse --serve
    serve_port = None
    if "--serve" in args:
        idx = args.index("--serve")
        if idx + 1 < len(args) and args[idx + 1].isdigit():
            serve_port = int(args[idx + 1])
        else:
            serve_port = 8080

    if serve_port:
        from http.server import HTTPServer, BaseHTTPRequestHandler

        class ArchVizHandler(BaseHTTPRequestHandler):
            def do_GET(self):
                # Route: /rules/<filename> → serve rule file content
                if self.path.startswith("/rules/"):
                    filename = self.path[len("/rules/"):]
                    rule_file = PROJECT_ROOT / ".opencode" / "rules" / filename
                    if rule_file.exists() and rule_file.is_file():
                        content = rule_file.read_text(encoding="utf-8")
                        highlighted = content.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
                        html = f"""<!DOCTYPE html><html><head><meta charset="UTF-8"><title>{filename} - Arch-Viz</title>
<style>body{{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',monospace;background:#0d1117;color:#c9d1d9;padding:24px;max-width:800px;margin:0 auto;}}
a{{color:#58a6ff;text-decoration:none;}}a:hover{{text-decoration:underline;}}
pre{{background:#161b22;border:1px solid #30363d;border-radius:8px;padding:20px;overflow-x:auto;white-space:pre-wrap;font-size:13px;line-height:1.5;color:#e6edf3;}}
h1{{color:#58a6ff;font-size:20px;}}</style></head><body>
<h1>📁 {filename}</h1>
<a href="/" target="_top">← Back to dashboard</a>
<pre>{highlighted}</pre></body></html>"""
                        self.send_response(200)
                        self.send_header("Content-Type", "text/html; charset=utf-8")
                        self.send_header("Cache-Control", "no-cache")
                        self.end_headers()
                        self.wfile.write(html.encode("utf-8"))
                        return
                    else:
                        self.send_response(404)
                        self.end_headers()
                        self.wfile.write(b"Rule not found")
                        return

                # API: spawn a task
                if self.path.startswith("/api/spawn"):
                    from urllib.parse import urlparse, parse_qs
                    params = parse_qs(urlparse(self.path).query)
                    name = params.get("name", ["task"])[0]
                    cmd = params.get("command", ["echo ok"])[0]
                    rl = int(params.get("ralph_loop", [0])[0])
                    rp = params.get("ralph_promise", [""])[0]
                    t = bg_spawn(name, cmd, ralph_loop=rl, ralph_promise=rp)
                    self.send_response(200)
                    self.send_header("Content-Type", "text/plain")
                    self.send_header("Access-Control-Allow-Origin", "*")
                    self.end_headers()
                    self.wfile.write(f"Spawned: {t.id}".encode())
                    return

                # API: tasks list (AJAX refresh)
                if self.path.startswith("/api/tasks"):
                    tasks = bg_list()
                    html = render_bg_tasks_html(tasks)
                    self.send_response(200)
                    self.send_header("Content-Type", "text/html; charset=utf-8")
                    self.send_header("Cache-Control", "no-cache")
                    self.end_headers()
                    self.wfile.write(html.encode("utf-8"))
                    return

                # API: Ralph Loop info
                if self.path.startswith("/api/ralph"):
                    tasks = bg_list()
                    ralph_tasks = [t for t in tasks if t.ralph_loop > 0]
                    lines = []
                    for t in ralph_tasks[-10:]:
                        icon = {"running":"🟢","pending":"🟡","completed":"✅","failed":"❌","cancelled":"⏹"}.get(t.status,"⬜")
                        promise = f" promise:'{t.ralph_promise[:20]}'" if t.ralph_promise else ""
                        lines.append(f"<div style='padding:4px 0;font-size:12px;border-bottom:1px solid #21262d;'>{t.id} {t.name} {icon} {t.status} retry {t.ralph_count}/{t.ralph_loop}{promise}</div>")
                    content = "".join(lines) if lines else "<div style='color:#8b949e;'>no ralph loops active</div>"
                    self.send_response(200)
                    self.send_header("Content-Type", "text/html; charset=utf-8")
                    self.send_header("Cache-Control", "no-cache")
                    self.end_headers()
                    self.wfile.write(content.encode("utf-8"))
                    return

                # API: live output (running + recently completed)
                if self.path.startswith("/api/live"):
                    tasks = bg_list()
                    running = [t for t in tasks if t.status == "running"]
                    recent = [t for t in tasks if t.status in ("completed", "failed", "cancelled")][-15:]
                    display = running + recent
                    if not display:
                        content = "<div style='padding:20px;font-size:12px;color:#8b949e;text-align:center;'>No tasks</div>"
                    else:
                        parts = []
                        for t in display[:15]:
                            tail = ""
                            if t.log_file and Path(t.log_file).exists():
                                lines = Path(t.log_file).read_text(encoding="utf-8", errors="replace").splitlines()
                                tail = "\n".join(lines[-6:])
                            icon = "🟢" if t.status == "running" else "✅" if t.status == "completed" else "❌"
                            opacity = "1" if t.status == "running" else "0.8"
                            parts.append(f"""<div style="border-bottom:1px solid #21262d;padding:12px 16px;opacity:{opacity};">
<div style="display:flex;justify-content:space-between;margin-bottom:6px;">
<span style="font-weight:600;font-size:12px;color:#58a6ff;">{icon} {t.name}</span>
<span style="font-size:11px;color:#8b949e;">{t.status}</span>
</div>
<pre style="background:#1c2128;padding:10px 14px;border-radius:6px;font-size:11px;line-height:1.5;overflow-x:auto;white-space:pre-wrap;color:#c9d1d9;margin:0;">{tail or "⏳ running..."}</pre>
</div>""")
                        content = "".join(parts)
                    self.send_response(200)
                    self.send_header("Content-Type", "text/html; charset=utf-8")
                    self.send_header("Cache-Control", "no-cache")
                    self.end_headers()
                    self.wfile.write(content.encode("utf-8"))
                    return

                # Default: dashboard
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Cache-Control", "no-cache, no-store, must-revalidate")
                self.send_header("Access-Control-Allow-Origin", "*")
                self.end_headers()
                graph = build_graph()
                self.wfile.write(render_html(graph).encode("utf-8"))

            def log_message(self, format, *args):
                pass  # quiet

        server = HTTPServer(("0.0.0.0", serve_port), ArchVizHandler)
        print(f"🌐 Arch-Viz dashboard: http://localhost:{serve_port}")
        print(f"   Press Ctrl+C to stop")
        try:
            server.serve_forever()
        except KeyboardInterrupt:
            print("\nServer stopped.")
        return

    if watch_mode:
        try:
            while True:
                os.system("clear" if sys.platform != "win32" else "cls")
                graph = build_graph()
                print(render_dashboard(graph))
                time.sleep(5)
        except KeyboardInterrupt:
            print("\nExiting watch mode.")
        return

    # Parse --bg subcommand
    if "--bg" in args:
        idx = args.index("--bg")
        bg_args = args[idx + 1:] if idx + 1 < len(args) else []
        if not bg_args:
            print("Usage: --bg spawn <name> <command>")
            print("       --bg list")
            print("       --bg logs <task_id>")
            print("       --bg cancel <task_id>")
            return
        subcmd = bg_args[0]
        if subcmd == "spawn" and len(bg_args) >= 3:
            name = bg_args[1]
            rl = 0
            rp = ""
            cmd_parts = bg_args[2:]
            if "--ralph" in cmd_parts:
                i = cmd_parts.index("--ralph")
                rl = int(cmd_parts[i+1]) if i+1 < len(cmd_parts) else 3
                cmd_parts = cmd_parts[:i] + cmd_parts[i+2:]
            if "--promise" in cmd_parts:
                i = cmd_parts.index("--promise")
                rp = cmd_parts[i+1] if i+1 < len(cmd_parts) else ""
                cmd_parts = cmd_parts[:i] + cmd_parts[i+2:]
            cmd = " ".join(cmd_parts)
            t = bg_spawn(name, cmd, ralph_loop=rl, ralph_promise=rp)
            info = f"🟢 Spawned: {t.id} ({t.name})  PID: {t.pid}"
            if rl: info += f"  Ralph: {rl}x"
            if rp: info += f"  promise: '{rp}'"
            print(info)
            return
        elif subcmd == "list":
            tasks = bg_list()
            if not tasks:
                print("(no tasks)")
            else:
                for t in tasks[-15:]:
                    icon = {"running": "🟢", "pending": "🟡", "completed": "✅", "failed": "❌", "cancelled": "⏹"}.get(t.status, "⬜")
                    print(f"  {t.id:<10} {t.name:<20} {icon} {t.status:<12} {str(t.pid or '-'):<8} {t.command[:40]}")
            return
        elif subcmd == "logs" and len(bg_args) >= 2:
            logs = bg_logs(bg_args[1])
            print(logs or "No logs")
            return
        elif subcmd == "cancel" and len(bg_args) >= 2:
            print("Cancelled" if bg_cancel(bg_args[1]) else "Not found")
            return
        else:
            print(f"Unknown: {subcmd}")
            return

    graph = build_graph()

    if export_format:
        exporters = {
            "json": (export_json, ".json"),
            "mermaid": (export_mermaid, ".mmd"),
            "excalidraw": (export_excalidraw, ".excalidraw"),
        }

        if export_format not in exporters:
            print(f"Unknown export format: {export_format}")
            print(f"Supported: {', '.join(exporters.keys())}")
            sys.exit(1)

        exporter, ext = exporters[export_format]
        if not output_path:
            output_path = f"arch-viz-{export_format}{ext}"

        result = exporter(graph, Path(output_path))
        if result:
            print(f"✅ Exported: {result}")
        else:
            print("❌ Export failed")
    else:
        print(render_dashboard(graph))


if __name__ == "__main__":
    main()
