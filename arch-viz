                            icon = "🟢" if t.status == "running" else "✅" if t.status == "completed" else "❌"
                            opacity = "1" if t.status == "running" else "0.8"
                            parts.append(f"""<div style="border-bottom:1px solid #21262d;padding:12px 16px;opacity:{opacity};">
<div style="display:flex;justify-content:space-between;margin-bottom:6px;">
<span style="font-weight:600;font-size:12px;color:#58a6ff;">{icon} {t.name}</span>
<span style="font-size:11px;color:#8b949e;">{t.status}</span>
</div>
<pre style="background:#1c2128;padding:10px 14px;border-radius:6px;font-size:11px;line-height:1.5;overflow-x:auto;white-space:pre-wrap;color:#c9d1d9;margin:0;">{tail or "⏳ running..."}</pre>
</div>""")
                        content = "".join(parts)
                    self.send_response(200)
                    self.send_header("Content-Type", "text/html; charset=utf-8")
                    self.send_header("Cache-Control", "no-cache")
                    self.end_headers()
                    self.wfile.write(content.encode("utf-8"))
                    return

                # Default: dashboard (serve HTML file)
                html_file = PROJECT_ROOT / ".opencode" / "dashboard.html"
                if html_file.exists():
                    content = html_file.read_text(encoding="utf-8")
                else:
                    content = "<html><body><h1>dashboard.html not found</h1></body></html>"
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Cache-Control", "no-cache, no-store, must-revalidate")
                self.send_header("Access-Control-Allow-Origin", "*")
                self.end_headers()
                self.wfile.write(content.encode("utf-8"))

            def log_message(self, format, *args):
                pass  # quiet

        server = HTTPServer(("0.0.0.0", serve_port), ArchVizHandler)
        print(f"🌐 Arch-Viz dashboard: http://localhost:{serve_port}")
        print(f"   Press Ctrl+C to stop")
        try:
            server.serve_forever()
        except KeyboardInterrupt:
            print("\nServer stopped.")
        return

    if watch_mode:
        try:
            while True:
                os.system("clear" if sys.platform != "win32" else "cls")
                graph = build_graph()
                print(render_dashboard(graph))
                time.sleep(5)
        except KeyboardInterrupt:
            print("\nExiting watch mode.")
        return

    # Parse --pipeline list (must check before general --pipeline)
    if "--pipeline" in args and "list" in args:
        pipelines = _load_pipelines()
        print(render_pipelines_terminal(pipelines))
        return

    # Parse --pipeline
    if "--pipeline" in args:
        idx = args.index("--pipeline")
        pipe_args = args[idx + 1:] if idx + 1 < len(args) else []
        if len(pipe_args) < 3:
            print("Usage: --pipeline <name> <description> <step1> [step2] [step3] ...")
            print("  Each step format: agent:task_description")
            print("  Example: --pipeline '登录功能' '实现用户登录' 'plan:设计登录架构' 'build:实现登录' 'test:写登录测试' 'reviewer:审查代码'")
            return
        name = pipe_args[0]
        desc = pipe_args[1]
        step_specs = pipe_args[2:]
        steps = []
        for spec in step_specs:
            if ":" in spec:
                agent, task = spec.split(":", 1)
            else:
                agent = "build"
                task = spec
            steps.append(PipelineStep(agent=agent.strip(), task=task.strip()))
        p = pipeline_create(name, desc, steps)
        pipeline_start(p.id)
        print(f"🚀 Pipeline created: {p.id} ({p.name})")
        print(f"   Steps: {len(steps)} ({', '.join(s.agent for s in steps)})")
        print(f"   Run 'av --bg list' or 'av --pipeline list' to track progress")
        return

    # Parse --review
    if "--review" in args:
        idx = args.index("--review")
        rv_args = args[idx + 1:] if idx + 1 < len(args) else []
        if not rv_args:
            print("Usage: --review submit <title> <description>")
            print("       --review list")
            print("       --review approve <review_id>")
            print("       --review changes <review_id> <comment>")
            print("       --review comment <review_id> <text>")
            return
        sub = rv_args[0]
        if sub == "submit" and len(rv_args) >= 3:
            title = rv_args[1]
            desc = " ".join(rv_args[2:])
            r = review_create(title, desc)
            print(f"📝 Review created: {r.id} ({r.title})")
            print(f"   Status: {r.status}")
            print(f"   Approve: av --review approve {r.id}")
            return
        elif sub == "list":
            print(render_reviews_terminal(_load_reviews()))
            return
        elif sub == "approve" and len(rv_args) >= 2:
            if review_approve(rv_args[1]):
                print(f"✅ Approved: {rv_args[1]}")
                # If pipeline is waiting, advance it
            else:
                print(f"Review not found: {rv_args[1]}")
            return
        elif sub == "changes" and len(rv_args) >= 3:
            if review_request_changes(rv_args[1], " ".join(rv_args[2:])):
                print(f"🔄 Changes requested: {rv_args[1]}")
            else:
                print(f"Review not found: {rv_args[1]}")
            return
        elif sub == "comment" and len(rv_args) >= 3:
            if review_add_comment(rv_args[1], "reviewer", " ".join(rv_args[2:])):
                print(f"💬 Comment added to {rv_args[1]}")
            else:
                print(f"Review not found: {rv_args[1]}")
            return
        else:
            print(f"Unknown: {sub}")
            return

    # Parse --bg subcommand
    if "--bg" in args:
        idx = args.index("--bg")
        bg_args = args[idx + 1:] if idx + 1 < len(args) else []
        if not bg_args:
            print("Usage: --bg spawn <name> <command>")
            print("       --bg list")
            print("       --bg logs <task_id>")
            print("       --bg cancel <task_id>")
            return
        subcmd = bg_args[0]
        if subcmd == "spawn" and len(bg_args) >= 3:
            name = bg_args[1]
            rl = 0
            rp = ""
            cmd_parts = bg_args[2:]
            if "--ralph" in cmd_parts:
                i = cmd_parts.index("--ralph")
                rl = int(cmd_parts[i+1]) if i+1 < len(cmd_parts) else 3
                cmd_parts = cmd_parts[:i] + cmd_parts[i+2:]
            if "--promise" in cmd_parts:
                i = cmd_parts.index("--promise")
                rp = cmd_parts[i+1] if i+1 < len(cmd_parts) else ""
                cmd_parts = cmd_parts[:i] + cmd_parts[i+2:]
            cmd = " ".join(cmd_parts)
            t = bg_spawn(name, cmd, ralph_loop=rl, ralph_promise=rp)
            info = f"🟢 Spawned: {t.id} ({t.name})  PID: {t.pid}"
            if rl: info += f"  Ralph: {rl}x"
            if rp: info += f"  promise: '{rp}'"
            print(info)
            return
        elif subcmd == "list":
            tasks = bg_list()
            if not tasks:
                print("(no tasks)")
            else:
                for t in tasks[-15:]:
                    icon = {"running": "🟢", "pending": "🟡", "completed": "✅", "failed": "❌", "cancelled": "⏹"}.get(t.status, "⬜")
                    print(f"  {t.id:<10} {t.name:<20} {icon} {t.status:<12} {str(t.pid or '-'):<8} {t.command[:40]}")
            return
        elif subcmd == "logs" and len(bg_args) >= 2:
            logs = bg_logs(bg_args[1])
            print(logs or "No logs")
            return
        elif subcmd == "cancel" and len(bg_args) >= 2:
            print("Cancelled" if bg_cancel(bg_args[1]) else "Not found")
            return
        else:
            print(f"Unknown: {subcmd}")
            return

    # --health: system health check
    if "--health" in args:
        import subprocess
        print(f"\n{'='*50}")
        print(f"  🩺 Arch-Viz Health Check")
        print(f"{'='*50}")

        # 1. Python
        py_ver = sys.version.split()[0]
        print(f"\n  Python:      {py_ver}")

        # 2. Config
        config_ok = "✅" if Path("opencode.json").exists() else "❌"
        print(f"  Config:      {config_ok} opencode.json")

        # 3. Background tasks
        tasks = _load_tasks()
        running = sum(1 for t in tasks if t.status == "running")
        total = len(tasks)
        print(f"  Tasks:       {total} total, {running} running")

        # 4. Pipelines
        pipelines = _load_pipelines()
        active = sum(1 for p in pipelines if p.status == "running")
        print(f"  Pipelines:   {len(pipelines)} total, {active} active")

        # 5. MCP
        mcp_ok = "✅" if any(t.status == "running" for t in tasks if "mcp" in t.name.lower()) else "?"
        print(f"  MCP:         {mcp_ok}")

        # 6. Dashboard
        import subprocess as sp
        port_check = sp.run(["lsof", "-ti", ":8080"], capture_output=True, text=True)
        server_ok = "✅" if port_check.stdout.strip() else "❌"
        print(f"  Dashboard:   {server_ok} (port 8080)")

        # 7. Skills
        skills_dir = Path(".agents/skills")
        skills_count = len([d for d in skills_dir.iterdir() if d.is_dir() and not d.name.startswith(".")]) if skills_dir.exists() else 0
        print(f"  Skills:      {skills_count} installed")

        print(f"\n{'='*50}\n")
        return

    graph = build_graph()

    if export_format:
        exporters = {
            "json": (export_json, ".json"),
            "mermaid": (export_mermaid, ".mmd"),
            "excalidraw": (export_excalidraw, ".excalidraw"),
        }

        if export_format not in exporters:
            print(f"Unknown export format: {export_format}")
            print(f"Supported: {', '.join(exporters.keys())}")
            sys.exit(1)

        exporter, ext = exporters[export_format]
        if not output_path:
            output_path = f"arch-viz-{export_format}{ext}"

        result = exporter(graph, Path(output_path))
        if result:
            print(f"✅ Exported: {result}")
        else:
            print("❌ Export failed")
    else:
        print(render_dashboard(graph))


if __name__ == "__main__":
    main()
